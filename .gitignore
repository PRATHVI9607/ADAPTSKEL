# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/
.env
*.env

# ── pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── C++ build artifacts ───────────────────────────────────────────────────────
*.o
*.a
*.so
*.dll
*.dylib
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
_deps/
build/

# ── Node / frontend ───────────────────────────────────────────────────────────
app/frontend/node_modules/
app/frontend/dist/
app/frontend/.vite/
app/routing-app/node_modules/
app/routing-app/dist/
app/routing-app/.vite/

# ── Benchmark datasets (can be large) ────────────────────────────────────────
benchmarks/datasets/*
!benchmarks/datasets/.gitkeep

# ── Benchmark results (auto-generated, keep .gitkeep) ────────────────────────
benchmarks/results/*
!benchmarks/results/.gitkeep

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Secrets / keys ───────────────────────────────────────────────────────────
*.pem
*.key
secrets.json
